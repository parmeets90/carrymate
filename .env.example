# ── App ──────────────────────────────
NODE_ENV=development
PORT=3000
APP_NAME=CarryMate
APP_VERSION=0.1.0
API_BASE_URL=http://localhost:3000
ADMIN_URL=http://localhost:5173

# ── Database ─────────────────────────
DATABASE_URL=postgresql://carrymate_user:local_secret@localhost:5432/carrymate

# ── JWT ──────────────────────────────
JWT_ACCESS_SECRET=replace_with_64_char_random_string
JWT_REFRESH_SECRET=replace_with_64_char_random_string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── OTP / SMS (MSG91) ────────────────
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=
OTP_EXPIRY_MINUTES=10

# ── KYC (IDFY) ───────────────────────
IDFY_ACCOUNT_ID=
IDFY_API_KEY=
IDFY_BASE_URL=https://eve.idfy.com/v3

# ── Payments (Razorpay) ──────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_ACCOUNT_NUMBER=

# ── AWS / S3 ─────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=carrymate-uploads
AWS_CLOUDFRONT_DOMAIN=

# ── Firebase (FCM push) ──────────────
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ── Email (SendGrid) ─────────────────
SENDGRID_API_KEY=
EMAIL_FROM=noreply@carrymate.in

# ── Feature flags (off by default) ───
ENABLE_REAL_PAYMENTS=false
ENABLE_AUTO_KYC=false
ENABLE_CHAT=false
ENABLE_CANADA=false
ENABLE_USA=false

# ── Fraud / Risk ─────────────────────
FRAUD_SCORE_THRESHOLD=70
MAX_DAILY_REQUESTS_PER_USER=3
MAX_ACTIVE_BIDS_PER_TRAVELER=5
