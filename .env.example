# ── App ──────────────────────────────
NODE_ENV=development
PORT=3000
APP_NAME=CarryMate
APP_VERSION=0.1.0
API_BASE_URL=http://localhost:3000
ADMIN_URL=http://localhost:5173

# CORS allowlist for browser clients (the admin web app), comma-separated.
# Enforced ONLY when NODE_ENV=production; dev reflects any origin.
# Native mobile + server-to-server send no Origin and are always allowed.
# e.g. CORS_ORIGINS=https://admin.carrymate.in,https://admin-staging.carrymate.in
CORS_ORIGINS=

# ── Database (Supabase Postgres) ─────
# Pooled (PgBouncer, port 6543) for the app runtime.
# NOTE: URL-encode special chars in the password (e.g. @ -> %40).
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# Direct/session (port 5432) for migrations.
DIRECT_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ── Admin (email + password login) ───
ADMIN_EMAIL=admin@carrymate.in
ADMIN_PASSWORD=change_me_strong_password

# ── JWT ──────────────────────────────
JWT_ACCESS_SECRET=replace_with_64_char_random_string
JWT_REFRESH_SECRET=replace_with_64_char_random_string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── OTP (Twilio Verify) ──────────────
# Leave blank in dev: OTPs are printed to the server console instead of sent.
# Create a Verify Service in Twilio Console → Verify → Services (SID starts VA...).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6

# ── KYC (IDFY) ───────────────────────
IDFY_ACCOUNT_ID=
IDFY_API_KEY=
IDFY_BASE_URL=https://eve.idfy.com/v3

# ── Payments (Razorpay) ──────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_ACCOUNT_NUMBER=

# ── Storage (Supabase Storage) ───────
# Project URL + service-role key (server-side only — never ship to clients).
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
STORAGE_BUCKET=carrymate

# ── Firebase (FCM push) ──────────────
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ── Email (SendGrid) ─────────────────
SENDGRID_API_KEY=
EMAIL_FROM=noreply@carrymate.in

# ── Feature flags (off by default) ───
ENABLE_REAL_PAYMENTS=false
ENABLE_AUTO_KYC=false
ENABLE_CHAT=false
ENABLE_CANADA=false
ENABLE_USA=false

# ── Fraud / Risk ─────────────────────
FRAUD_SCORE_THRESHOLD=70
MAX_DAILY_REQUESTS_PER_USER=3
MAX_ACTIVE_BIDS_PER_TRAVELER=5
