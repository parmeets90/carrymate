// CarryMate — Prisma schema.
// Phase 0 baseline: datasource, generator, shared enums, and a minimal User model.
// Domain models (kyc_documents, travel_routes, delivery_requests, bids, transactions,
// conversations, messages, ratings, disputes, notifications) are added per phase via
// additive, forward-only migrations. Keep enums in sync with packages/shared/src/enums.ts.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SENDER
  TRAVELER
  BOTH
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum KycStatus {
  PENDING
  IN_REVIEW
  VERIFIED
  REJECTED
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  phone        String     @unique @db.VarChar(15) // E.164, e.g. +919876543210
  email        String?    @unique @db.VarChar(255)
  fullName     String?    @map("full_name") @db.VarChar(100)
  role         UserRole   @default(SENDER)
  status       UserStatus @default(ACTIVE)
  kycStatus    KycStatus  @default(PENDING) @map("kyc_status")
  phoneVerified Boolean   @default(false) @map("phone_verified")
  language     String     @default("en") @db.VarChar(5)
  ratingAvg    Decimal    @default(5.0) @map("rating_avg") @db.Decimal(3, 2)
  ratingCount  Int        @default(0) @map("rating_count")
  fcmToken     String?    @map("fcm_token")
  lastActiveAt DateTime?  @map("last_active_at") @db.Timestamptz
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz

  refreshTokens RefreshToken[]

  @@index([kycStatus])
  @@index([status])
  @@index([role])
  @@map("users")
}

/// One-time passcodes for phone login. Codes are stored hashed, never plaintext.
model PhoneOtp {
  id         String    @id @default(uuid()) @db.Uuid
  phone      String    @db.VarChar(15)
  codeHash   String    @map("code_hash")
  attempts   Int       @default(0)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@index([phone, createdAt])
  @@map("phone_otps")
}

/// Hashed refresh tokens for rotation + revocation (no Redis in this stack).
model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}
