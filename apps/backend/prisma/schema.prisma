// CarryMate — Prisma schema.
// Phase 0 baseline: datasource, generator, shared enums, and a minimal User model.
// Domain models (kyc_documents, travel_routes, delivery_requests, bids, transactions,
// conversations, messages, ratings, disputes, notifications) are added per phase via
// additive, forward-only migrations. Keep enums in sync with packages/shared/src/enums.ts.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Supabase: pooled connection (PgBouncer, port 6543) for the app runtime.
  url       = env("DATABASE_URL")
  // Direct connection (port 5432) for migrations / introspection.
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  SENDER
  TRAVELER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum KycStatus {
  PENDING
  VERIFYING // submitted to IDFY, awaiting the async result
  IN_REVIEW // needs a human (manual review queue)
  VERIFIED
  REJECTED
}

enum KycDocType {
  AADHAAR
  PAN
  PASSPORT
  SELFIE
  FLIGHT_TICKET
}

enum KycDocStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  // Optional now that Google (Firebase) sign-up exists; verified later in profile.
  phone        String?    @unique @db.VarChar(15) // E.164, e.g. +919876543210
  email        String?    @unique @db.VarChar(255)
  firebaseUid  String?    @unique @map("firebase_uid") // set for Google/Firebase accounts
  fullName     String?    @map("full_name") @db.VarChar(100)
  role         UserRole   @default(SENDER)
  status       UserStatus @default(ACTIVE)
  kycStatus    KycStatus  @default(PENDING) @map("kyc_status")
  // KYC resilience (Challenge 02): retry counter, last failure reason, and when
  // the doc was submitted to IDFY (drives the timeout→manual watcher).
  selfieAttemptCount Int       @default(0) @map("selfie_attempt_count")
  kycFailureReason   String?   @map("kyc_failure_reason")
  kycSubmittedAt     DateTime? @map("kyc_submitted_at") @db.Timestamptz
  phoneVerified Boolean   @default(false) @map("phone_verified")
  passwordHash String?    @map("password_hash") // admins only (email + password login)
  language     String     @default("en") @db.VarChar(5)
  ratingAvg    Decimal    @default(5.0) @map("rating_avg") @db.Decimal(3, 2)
  ratingCount  Int        @default(0) @map("rating_count")
  fcmToken     String?    @map("fcm_token")
  lastActiveAt DateTime?  @map("last_active_at") @db.Timestamptz
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz

  refreshTokens   RefreshToken[]
  kycDocuments    KycDocument[]
  travelRoutes    TravelRoute[]
  deliveryRequests DeliveryRequest[]
  bids            Bid[]
  ordersAsSender   Order[] @relation("OrderSender")
  ordersAsTraveler Order[] @relation("OrderTraveler")
  notifications    Notification[]
  bankAccount      BankAccount?

  @@index([kycStatus])
  @@index([status])
  @@index([role])
  @@map("users")
}

/// One-time passcodes for phone login. Codes are stored hashed, never plaintext.
model PhoneOtp {
  id         String    @id @default(uuid()) @db.Uuid
  phone      String    @db.VarChar(15)
  codeHash   String    @map("code_hash")
  attempts   Int       @default(0)
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@index([phone, createdAt])
  @@map("phone_otps")
}

/// A submitted identity document, reviewed manually (Phase 1) or via IDFY (later).
model KycDocument {
  id             String       @id @default(uuid()) @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  docType        KycDocType   @map("doc_type")
  docNumberMasked String?     @map("doc_number_masked") @db.VarChar(32)
  docNumberHash  String?      @map("doc_number_hash")
  fileKey        String?      @map("file_key") // storage object key (S3), never a public URL
  status         KycDocStatus @default(PENDING)
  rejectReason   String?      @map("reject_reason")
  reviewedById   String?      @map("reviewed_by_id") @db.Uuid
  reviewedAt     DateTime?    @map("reviewed_at") @db.Timestamptz
  provider       String?      // "manual" | "idfy"
  providerRef    String?      @map("provider_ref")
  meta           Json?
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, docType])
  @@index([userId])
  @@index([status])
  @@map("kyc_documents")
}

/// Hashed refresh tokens for rotation + revocation (no Redis in this stack).
model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ── Phase 2: Marketplace Core ─────────────────────────────────

enum RequestCategory {
  FOOD
  DOCUMENTS
  CLOTHING
  GIFTS
  OTHER
}

enum RequestStatus {
  OPEN
  BIDDING
  MATCHED
  IN_TRANSIT
  DELIVERED
  CONFIRMED
  DISPUTED
  CANCELLED
  EXPIRED
  PENDING_REVIEW // flagged by prohibited-item rules; awaiting an admin decision
}

enum RouteStatus {
  ACTIVE
  FULL
  COMPLETED
  CANCELLED
  EXPIRED // departure date passed — no longer accepts bids (Challenge 09, Layer 3)
}

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
  EXPIRED
}

enum PickupPreference {
  AIRPORT
  DOORSTEP
  MEETUP
}

// Single source of truth for the money path (Challenge 03 — 7-state FSM).
// Forward-only happy path; REFUNDED/DISPUTED are exception branches.
enum OrderStatus {
  PENDING_PAYMENT
  ESCROW_HELD
  IN_TRANSIT
  DELIVERY_PROOF_UPLOADED
  PAYOUT_INITIATED
  COMPLETED
  REFUNDED
  DISPUTED
}

enum PayoutStatus {
  NONE
  INITIATED
  PAID
  FAILED
}

/// A traveler's announced journey with spare luggage capacity.
model TravelRoute {
  id                 String      @id @default(uuid()) @db.Uuid
  travelerId         String      @map("traveler_id") @db.Uuid
  flightNumber       String?     @map("flight_number") @db.VarChar(10)
  airline            String?     @db.VarChar(50)
  originAirport      String      @map("origin_airport") @db.VarChar(3)
  destinationAirport String      @map("destination_airport") @db.VarChar(3)
  departureDate      DateTime    @map("departure_date") @db.Date
  arrivalDate        DateTime?   @map("arrival_date") @db.Date
  capacityKg         Decimal     @map("capacity_kg") @db.Decimal(4, 1)
  capacityUsedKg     Decimal     @default(0) @map("capacity_used_kg") @db.Decimal(4, 1)
  ticketFileKey      String?     @map("ticket_file_key")
  ticketVerified     Boolean     @default(false) @map("ticket_verified")
  deliveryArea       String?     @map("delivery_area") @db.VarChar(100)
  notes              String?
  status             RouteStatus @default(ACTIVE)
  createdAt          DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  traveler User  @relation(fields: [travelerId], references: [id], onDelete: Cascade)
  bids     Bid[]

  @@index([travelerId])
  @@index([destinationAirport, departureDate, status])
  @@map("travel_routes")
}

/// A sender's request to move a personal item.
model DeliveryRequest {
  id                    String          @id @default(uuid()) @db.Uuid
  senderId              String          @map("sender_id") @db.Uuid
  title                 String          @db.VarChar(100)
  description           String
  category              RequestCategory
  weightKg              Decimal         @map("weight_kg") @db.Decimal(4, 1)
  declaredValueInr      Int             @map("declared_value_inr")
  itemPhotos            String[]        @map("item_photos")
  originCity            String          @map("origin_city") @db.VarChar(50)
  originAirport         String          @map("origin_airport") @db.VarChar(3)
  destinationCountry    String          @default("UAE") @map("destination_country") @db.VarChar(3)
  destinationCity       String          @map("destination_city") @db.VarChar(50)
  recipientName         String          @map("recipient_name") @db.VarChar(100)
  recipientPhone        String          @map("recipient_phone") @db.VarChar(15)
  recipientAddress      String          @map("recipient_address")
  deadlineDate          DateTime        @map("deadline_date") @db.Date
  isFragile             Boolean         @default(false) @map("is_fragile")
  senderNotes           String?         @map("sender_notes")
  status                RequestStatus   @default(OPEN)
  matchedTravelerId     String?         @map("matched_traveler_id") @db.Uuid
  acceptedBidId         String?         @map("accepted_bid_id") @db.Uuid
  prohibitedCheckPassed Boolean         @default(false) @map("prohibited_check_passed")
  expiresAt             DateTime?       @map("expires_at") @db.Timestamptz
  // Cold-start UX (Challenge 05): one free re-list, and a 48h pre-expiry nudge.
  relistCount           Int             @default(0) @map("relist_count")
  expiryReminderSentAt  DateTime?       @map("expiry_reminder_sent_at") @db.Timestamptz
  // Legal declaration accepted at submission (Challenge 08).
  declarationAcceptedAt DateTime?       @map("declaration_accepted_at") @db.Timestamptz
  declarationIp         String?         @map("declaration_ip") @db.VarChar(64)
  createdAt             DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  sender User   @relation(fields: [senderId], references: [id], onDelete: Cascade)
  bids   Bid[]
  order  Order?

  @@index([senderId])
  @@index([status])
  @@index([destinationCity, deadlineDate, status])
  @@map("delivery_requests")
}

/// A traveler's offer to carry a request on one of their routes.
model Bid {
  id                    String           @id @default(uuid()) @db.Uuid
  requestId             String           @map("request_id") @db.Uuid
  travelerId            String           @map("traveler_id") @db.Uuid
  routeId               String           @map("route_id") @db.Uuid
  carryFeeInr           Int              @map("carry_fee_inr")
  commissionInr         Int              @map("commission_inr")
  payoutInr             Int              @map("payout_inr")
  message               String?
  pickupPreference      PickupPreference @map("pickup_preference")
  pickupLocation        String?          @map("pickup_location")
  estimatedDeliveryDate DateTime         @map("estimated_delivery_date") @db.Date
  status                BidStatus        @default(PENDING)
  createdAt             DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  request  DeliveryRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  traveler User            @relation(fields: [travelerId], references: [id], onDelete: Cascade)
  route    TravelRoute     @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@unique([requestId, travelerId])
  @@index([requestId])
  @@index([travelerId])
  @@index([status])
  @@map("bids")
}

/// Created when a sender accepts a bid; carries the escrow/payment lifecycle.
model Order {
  id            String      @id @default(uuid()) @db.Uuid
  requestId     String      @unique @map("request_id") @db.Uuid
  bidId         String      @unique @map("bid_id") @db.Uuid
  senderId      String      @map("sender_id") @db.Uuid
  travelerId    String      @map("traveler_id") @db.Uuid
  amountInr     Int         @map("amount_inr")
  commissionInr Int         @map("commission_inr")
  payoutInr     Int         @map("payout_inr")
  status        OrderStatus @default(PENDING_PAYMENT)
  paymentMethod String?     @map("payment_method") // "stub" | "upi" | "card" | ...
  razorpayOrderId   String? @unique @map("razorpay_order_id")
  razorpayPaymentId String? @unique @map("razorpay_payment_id")
  razorpayRefundId  String? @map("razorpay_refund_id")
  escrowHeldAt  DateTime?   @map("escrow_held_at") @db.Timestamptz
  releasedAt    DateTime?   @map("released_at") @db.Timestamptz
  refundedAt    DateTime?   @map("refunded_at") @db.Timestamptz
  // Payout tracking (Challenge 03 — failed-payout recovery)
  payoutStatus        PayoutStatus @default(NONE) @map("payout_status")
  payoutFailureReason String?      @map("payout_failure_reason")
  payoutInitiatedAt   DateTime?    @map("payout_initiated_at") @db.Timestamptz
  payoutPaidAt        DateTime?    @map("payout_paid_at") @db.Timestamptz
  // Risk / fraud (Phase 6)
  riskScore        Int       @default(0) @map("risk_score")
  riskFactors      String[]  @default([]) @map("risk_factors")
  fraudHold        Boolean   @default(false) @map("fraud_hold") // blocks escrow release until an admin clears it
  fraudClearedAt   DateTime? @map("fraud_cleared_at") @db.Timestamptz
  fraudClearedById String?   @map("fraud_cleared_by_id") @db.Uuid
  // Fulfillment (Phase 4)
  openBox       Json?       @map("open_box") // checklist + photo keys + gps + ts
  openBoxAt     DateTime?   @map("open_box_at") @db.Timestamptz
  deliveryOtp   String?     @map("delivery_otp_hash") // 6-digit handover code (shown to sender)
  deliveryProof String[]    @default([]) @map("delivery_proof") // S3 keys
  pickedUpAt    DateTime?   @map("picked_up_at") @db.Timestamptz
  deliveredAt   DateTime?   @map("delivered_at") @db.Timestamptz
  autoConfirmAt DateTime?   @map("auto_confirm_at") @db.Timestamptz
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  request  DeliveryRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  sender   User            @relation("OrderSender", fields: [senderId], references: [id])
  traveler User            @relation("OrderTraveler", fields: [travelerId], references: [id])
  dispute  Dispute?
  ratings  Rating[]
  conversation Conversation?
  stateLogs    PaymentStateLog[]
  inspection   InspectionRecord?

  @@index([senderId])
  @@index([travelerId])
  @@index([status, autoConfirmAt])
  @@map("orders")
}

enum DisputeReason {
  ITEM_NOT_DELIVERED
  ITEM_DAMAGED
  WRONG_ITEM
  FRAUD
  OTHER
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_SENDER
  RESOLVED_TRAVELER
}

/// A dispute on an order. Freezes escrow until an admin resolves it.
model Dispute {
  id             String        @id @default(uuid()) @db.Uuid
  orderId        String        @unique @map("order_id") @db.Uuid
  raisedById     String        @map("raised_by_id") @db.Uuid
  reason         DisputeReason
  description    String
  evidence       String[]      @default([]) // S3 keys
  status         DisputeStatus @default(OPEN)
  resolvedById   String?       @map("resolved_by_id") @db.Uuid
  resolutionNote String?       @map("resolution_note")
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz
  resolvedAt     DateTime?     @map("resolved_at") @db.Timestamptz

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("disputes")
}

/// Bidirectional post-delivery rating.
model Rating {
  id        String   @id @default(uuid()) @db.Uuid
  orderId   String   @map("order_id") @db.Uuid
  raterId   String   @map("rater_id") @db.Uuid
  rateeId   String   @map("ratee_id") @db.Uuid
  stars     Int
  comment   String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId, raterId])
  @@index([rateeId])
  @@map("ratings")
}

// ── Phase 5: Communications ───────────────────────────────────

enum MessageType {
  TEXT
  IMAGE
  SYSTEM
}

enum NotificationChannel {
  PUSH
  SMS
  EMAIL
  IN_APP
}

enum NotificationType {
  BID_RECEIVED
  BID_ACCEPTED
  ORDER_PAID
  OPEN_BOX_DONE
  IN_TRANSIT
  DELIVERED
  ESCROW_RELEASED
  DISPUTE_OPENED
  DISPUTE_RESOLVED
  KYC_VERIFIED
  KYC_REJECTED
  NEW_MESSAGE
  RATING_RECEIVED
  SYSTEM
}

/// One chat thread per order. Unlocks only once escrow is held (anti-disintermediation).
/// Participant phone/email is never exchanged here — messages are PII-filtered server-side.
model Conversation {
  id                 String    @id @default(uuid()) @db.Uuid
  orderId            String    @unique @map("order_id") @db.Uuid
  senderId           String    @map("sender_id") @db.Uuid
  travelerId         String    @map("traveler_id") @db.Uuid
  lastMessageAt      DateTime? @map("last_message_at") @db.Timestamptz
  senderLastReadAt   DateTime? @map("sender_last_read_at") @db.Timestamptz
  travelerLastReadAt DateTime? @map("traveler_last_read_at") @db.Timestamptz
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz

  order    Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([senderId])
  @@index([travelerId])
  @@map("conversations")
}

/// A single chat message. `body` is stored already PII-redacted; `piiRedacted` flags
/// whether anything was stripped so the UI can hint why.
model Message {
  id             String      @id @default(uuid()) @db.Uuid
  conversationId String      @map("conversation_id") @db.Uuid
  senderId       String      @map("sender_id") @db.Uuid
  type           MessageType @default(TEXT)
  body           String
  piiRedacted    Boolean     @default(false) @map("pii_redacted")
  createdAt      DateTime    @default(now()) @map("created_at") @db.Timestamptz

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

// ── Phase 6: Safety, Fraud & Admin Hardening ──────────────────

enum AuditAction {
  KYC_APPROVED
  KYC_REJECTED
  KYC_DUPLICATE_FLAGGED
  DISPUTE_RESOLVED
  ORDER_REFUNDED
  ORDER_FRAUD_HOLD
  ORDER_HOLD_CLEARED
  USER_STATUS_CHANGED
  USER_AUTO_SUSPENDED
}

/// Open-box inspection record (Challenge 01 — the legal firewall). One per order.
/// Photos carry per-image GPS + timestamp; a summary PDF is generated after submit.
model InspectionRecord {
  id         String   @id @default(uuid()) @db.Uuid
  orderId    String   @unique @map("order_id") @db.Uuid
  travelerId String   @map("traveler_id") @db.Uuid
  photos     Json // [{ key, lat, lng, takenAt }]
  checklist  Json // { inspected, contentsMatch, noProhibited, sealed }
  pdfKey     String?  @map("pdf_key") // storage key of the generated summary PDF
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([travelerId])
  @@map("inspection_records")
}

/// Append-only log of every payment-state transition (Challenge 03).
/// The FSM is the only writer; this is the audit trail for reconciliation.
model PaymentStateLog {
  id           String   @id @default(uuid()) @db.Uuid
  orderId      String   @map("order_id") @db.Uuid
  fromState    String   @map("from_state") @db.VarChar(32)
  toState      String   @map("to_state") @db.VarChar(32)
  triggerEvent String   @map("trigger_event") @db.VarChar(64)
  meta         Json?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@map("payment_state_logs")
}

/// Idempotency ledger for inbound webhooks (Challenge 03). A unique (provider,
/// event_id) means a redelivered webhook is recognised and skipped.
model WebhookEvent {
  id          String   @id @default(uuid()) @db.Uuid
  provider    String   @db.VarChar(32)
  eventId     String   @map("event_id")
  type        String?  @db.VarChar(64)
  payload     Json?
  processedAt DateTime @default(now()) @map("processed_at") @db.Timestamptz

  @@unique([provider, eventId])
  @@map("webhook_events")
}

/// A traveler's payout destination. Locked while a delivery is mid-flight so the
/// money can't be redirected after escrow is held (Challenge 03, Fix 4).
model BankAccount {
  id                  String   @id @default(uuid()) @db.Uuid
  userId              String   @unique @map("user_id") @db.Uuid
  accountHolderName   String   @map("account_holder_name") @db.VarChar(100)
  accountNumberMasked String   @map("account_number_masked") @db.VarChar(32)
  accountNumberHash   String   @map("account_number_hash")
  ifsc                String   @db.VarChar(15)
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("bank_accounts")
}

/// Immutable trail of sensitive admin + system actions, for ops & compliance.
model AuditLog {
  id         String      @id @default(uuid()) @db.Uuid
  actorId    String?     @map("actor_id") @db.Uuid // admin user; null = system/automated
  action     AuditAction
  entityType String      @map("entity_type") @db.VarChar(40)
  entityId   String?     @map("entity_id") @db.Uuid
  meta       Json?
  ip         String?     @db.VarChar(64)
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamptz

  @@index([entityType, entityId])
  @@index([action, createdAt])
  @@map("audit_logs")
}

/// An in-app notification. External channels (PUSH/SMS/EMAIL) are dispatched best-effort
/// alongside the IN_APP record when configured; the IN_APP row is the source of truth.
model Notification {
  id        String              @id @default(uuid()) @db.Uuid
  userId    String              @map("user_id") @db.Uuid
  type      NotificationType
  title     String              @db.VarChar(120)
  body      String
  data      Json?
  channel   NotificationChannel @default(IN_APP)
  readAt    DateTime?           @map("read_at") @db.Timestamptz
  createdAt DateTime            @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@map("notifications")
}
